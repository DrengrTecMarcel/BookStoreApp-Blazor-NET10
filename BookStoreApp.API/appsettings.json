{
  "ConnectionStrings": {
    "BookStoreAppDbConnection": "Server=BULRIK\\SQLEXPRESS;Database=BookStoreAppDB;Trusted_Connection=True;MultipleActiveResultSets=True;Encrypt=False"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ]

  },
  "JwtSettings": {
    "Issuer": "BookstoreAPI",
    "Audience": "BookStoreApiClient",
    "Duration": 2   
  },
  "AllowedHosts": "*"
}
