@page "/authors/details/{id:int}"
@inject IAuthorService authorService
@inject NavigationManager navManager

<h3>Author Details</h3>

<EditForm Model="Author">
   <fieldset disabled="true">
        <div class="form-group">
            <lable for="firstname">First Name</lable>
            <InputText @bind-Value="Author.FirstName" class="form-control" id="firstname" />
            <ValidationMessage For="@(() => Author.FirstName)" />
        </div>
        <br />
        <div class="form-group">
            <lable for="lastname">Last Name</lable>
            <InputText @bind-Value="Author.LastName" class="form-control" id="lastname" />
            <ValidationMessage For="@(() => Author.LastName)" />
        </div>
        <br />
        <div class="form-group">
            <lable for="bio">Biography</lable>
            <InputText @bind-Value="Author.Bio" class="form-control" id="bio" />
            <ValidationMessage For="@(() => Author.Bio)" />
        </div>
        <br />
    </fieldset>
    
    @if (Author.Books == null || Author.Books.Any() == false)
    {
        <div class="alert alert-dismissible alert-secondary">
            No Books for this Author
        </div>   
    }
    else
    {
        <div class="row">
            @foreach (var book in Author.Books)
            {
                <div class="col-3">
                    <div class="card" style="width:202px; height:400px 18rem;">
                        <img src="@book.Image" class="card-img-top" alt="@book.Title" style="width:200px; height:300px"/>
                        <div class="card-body">
                            <h5 class="card-title">@book.Title</h5>
                            <h5>@book.Price.ToString("C")</h5>
                            <p class="card-text"></p>
                            <a href="/books/details/@book.Id" class="btn btn-primary">Book View</a>
                        </div>
                    </div>
                </div>           
            }
        </div>                  
    }
    <br />
    <button class="btn btn-outline-warning" @onclick="GoToUpdate" type="button">Update</button>
    <button class="btn btn-outline-secondary" @onclick="BackToList" type="button">Back To List</button>
    
</EditForm>

@code {
    [Parameter]
    public int id { get; set; }
    

    private AuthorDetailsDto Author = new AuthorDetailsDto();

    protected async override Task OnInitializedAsync()
    {
        var response = await authorService.GetAuthor(id); 
        if (response.Success)
        {
            Author = response.Data;                 
        }
        
    }

    private void BackToList()
    {
        navManager.NavigateTo("/authors/");
    }

    private void GoToUpdate()
    {
        navManager.NavigateTo($"/authors/update/{@Author.Id}");
    }
}
