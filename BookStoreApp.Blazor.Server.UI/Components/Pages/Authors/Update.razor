@page "/authors/update/{id:int}"
@inject IAuthorService authorService
@inject NavigationManager navManager
@attribute [Authorize(Roles = Roles.Administrator)]

<h3>Update Author</h3>

<EditForm Model="Author">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="form-group">
        <lable for="firstname">First Name</lable>
        <InputText @bind-Value="Author.FirstName" class="form-control" id="firstname" />
        <ValidationMessage For="@(() => Author.FirstName)" />
    </div>
    <br />
    <div class="form-group">
        <lable for="lastname">Last Name</lable>
        <InputText @bind-Value="Author.LastName" class="form-control" id="lastname" />
        <ValidationMessage For="@(() => Author.LastName)" />
    </div>
    <br />
    <div class="form-group">
        <lable for="bio">Biography</lable>
        <InputText @bind-Value="Author.Bio" class="form-control" id="bio" />
        <ValidationMessage For="@(() => Author.Bio)" />
    </div>
    <br />
    <button class="btn btn-primary" @onclick="HandleUpdateAuthor" type="submit">Update Author</button>
    <button class="btn btn-outline-secondary" @onclick="BackToList" type="button">Back To List</button>

</EditForm>
@code {
    [Parameter]
    public int id { get; set; }

    private AuthorUpdateDto Author = new AuthorUpdateDto();

    protected async override Task OnInitializedAsync()
    {
        var response = await authorService.GetUpdateForAuthors(id);
        if (response.Success)
        {
            Author = response.Data;
        }
    }

    private async Task HandleUpdateAuthor()
    {
        var response = await authorService.EditAuthor(id, Author);
        if (response.Success)
        {
            BackToList();
        }
    }

    private void BackToList()
    {
        navManager.NavigateTo("/authors/");
    }
}
